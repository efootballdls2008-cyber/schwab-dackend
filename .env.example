# Server
PORT=3001
NODE_ENV=development

# CORS - comma-separated origins for production, or * for all
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=schwab_db
DB_USER=schwab_user
DB_PASSWORD=schwab_pass
DB_ROOT_PASSWORD=rootpassword

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_MAX=100

# Email Configuration (Resend)
EMAIL_ENABLED=false
RESEND_API_KEY=re_XE1oqAc4_3WivHXjffchzwCVUvcw8GJay
EMAIL_FROM=onboarding@resend.dev
EMAIL_FROM_NAME=Charles Schwab Trading Platform
ADMIN_EMAIL=Paxfulexchangecompany@gmail.com

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173

# Default Admin Account (seeded on first startup if no admin exists)
ADMIN_SEED_EMAIL=Paxfulexchangecompany@gmail.com
ADMIN_SEED_PASSWORD=admin@5555
ADMIN_SEED_FIRST_NAME=Admin
ADMIN_SEED_LAST_NAME=Schwab
