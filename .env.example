# Server
PORT=3001
NODE_ENV=development

# CORS - comma-separated origins for production, or * for all
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=schwab_db
DB_USER=schwab_user
DB_PASSWORD=schwab_pass
DB_ROOT_PASSWORD=rootpassword

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500

# Email Configuration
EMAIL_ENABLED=true
EMAIL_SERVICE=smtp
# Options: smtp, gmail, sendgrid

# SMTP Configuration (for generic SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password

# Gmail Configuration (if using gmail)
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASSWORD=your_app_password

# SendGrid Configuration (if using sendgrid)
# SENDGRID_API_KEY=your_sendgrid_api_key

# Email Settings
EMAIL_FROM=noreply@schwab-trading.com
EMAIL_FROM_NAME=Charles Schwab Trading Platform
ADMIN_EMAIL=admin@schwab-trading.com

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173
